# Environment Variables Template
# Copy this file to .env and fill in your actual values

# AI Integrations
# Gemini works through the OpenAI-compatible endpoint:
# https://generativelanguage.googleapis.com/v1beta/openai/
AI_INTEGRATIONS_OPENAI_API_KEY=your_gemini_api_key_here
AI_INTEGRATIONS_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
AI_INTEGRATIONS_CHAT_MODEL=gemini-2.5-flash
AI_INTEGRATIONS_VISION_MODEL=gemini-2.5-flash

# Database Configuration
DATABASE_URL=file:./database.sqlite

# Server Configuration
NODE_ENV=development
PORT=5000

# Optional: For production deployment
# CORS_ORIGIN=https://yourusername.github.io
# SESSION_SECRET=your_session_secret_here
